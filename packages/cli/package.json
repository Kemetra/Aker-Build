  "private": true,
  "description": "Aker Build CLI — scan, gates, queue, route, prompt, and review PRs safely",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kemetra/Aker-Build.git",
