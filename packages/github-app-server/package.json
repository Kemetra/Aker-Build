{
  "name": "@aker-build/github-app-server",
  "version": "0.0.0",
  "description": "Aker Build report-only GitHub App — self-hostable deployment runtime (webhook server + concrete GitHub Checks client + ephemeral git workspace)",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "bin": {
    "aker-build-app-server": "./src/bin.ts"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aker-build/github-app": "workspace:*",
    "@aker-build/scanner": "workspace:*",
    "@octokit/auth-app": "^7.1.5",
    "@octokit/rest": "^21.1.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "esbuild": "0.28.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
